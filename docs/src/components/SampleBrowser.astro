---
/**
 * SampleBrowser — browse-only component that:
 * 1. Fetches samples-index.json from graph.pm
 * 2. Shows a searchable, filterable list of community query samples
 * 3. Each sample has an edit link to the GitHub file
 * 4. Product filter is populated dynamically from the index
 */
---

<div class="sample-browser" id="sample-browser">
  <!-- Top bar — search + filter + contribute button -->
  <div class="sb-topbar">
    <div class="sb-controls">
      <input
        type="text"
        id="sb-search"
        class="sb-search-input"
        placeholder="Search samples (e.g. conditional access, send email, managed devices)..."
        autocomplete="off"
      />
      <select id="sb-product-filter" class="sb-select">
        <option value="">All products</option>
      </select>
    </div>
    <a href="/improve/add-sample/" class="sb-btn sb-btn-contribute">
      <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M8 2a.75.75 0 0 1 .75.75v4.5h4.5a.75.75 0 0 1 0 1.5h-4.5v4.5a.75.75 0 0 1-1.5 0v-4.5h-4.5a.75.75 0 0 1 0-1.5h4.5v-4.5A.75.75 0 0 1 8 2Z"/></svg>
      Add a Sample
    </a>
  </div>

  <!-- Results count -->
  <div class="sb-status" id="sb-status">Loading samples...</div>

  <!-- Sample cards -->
  <div class="sb-results" id="sb-results"></div>
</div>

<script>
  const SAMPLES_INDEX_URL = 'https://graph.pm/samples-index.json';
  const GITHUB_EDIT_BASE = 'https://github.com/merill/msgraph/edit/main/skills/msgraph/samples/';

  let allSamples = [];

  // ── Load samples ──
  async function loadSamples() {
    const status = document.getElementById('sb-status');

    try {
      const resp = await fetch(SAMPLES_INDEX_URL);
      if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
      const data = await resp.json();
      allSamples = data.samples || [];
      populateProductFilter(allSamples);
      renderSamples(allSamples);
    } catch (err) {
      if (status) status.textContent = 'Failed to load samples. Try refreshing the page.';
      console.error('Failed to load samples:', err);
    }
  }

  // ── Populate product filter dynamically ──
  function populateProductFilter(samples) {
    const select = document.getElementById('sb-product-filter');
    if (!select) return;

    const products = [...new Set(samples.map(s => s.product))].sort();
    for (const p of products) {
      const opt = document.createElement('option');
      opt.value = p;
      opt.textContent = p.charAt(0).toUpperCase() + p.slice(1);
      select.appendChild(opt);
    }
  }

  // ── Render samples ──
  function renderSamples(samples) {
    const status = document.getElementById('sb-status');
    const results = document.getElementById('sb-results');
    if (!status || !results) return;

    if (samples.length === 0) {
      status.textContent = 'No samples match your search.';
      results.innerHTML = '';
      return;
    }

    status.textContent = `${samples.length} sample${samples.length === 1 ? '' : 's'}`;

    results.innerHTML = samples.map(s => {
      const queries = Array.isArray(s.query) ? s.query : [s.query];
      const isMultiStep = queries.length > 1;
      const queryHtml = queries.map((q, i) => {
        const label = isMultiStep ? `<span class="sb-step-label">Step ${i + 1}</span>` : '';
        return `<div class="sb-query-line">${label}<code>${escapeHtml(q)}</code></div>`;
      }).join('');

      const editUrl = GITHUB_EDIT_BASE + s.file;

      return `
        <div class="sb-card">
          <div class="sb-card-header">
            <span class="sb-card-product">${escapeHtml(s.product)}</span>
            ${isMultiStep ? '<span class="sb-card-badge">multi-step</span>' : ''}
            <a href="${editUrl}" target="_blank" rel="noopener" class="sb-edit-link" title="Edit this sample on GitHub">
              <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M11.013 1.427a1.75 1.75 0 0 1 2.474 0l1.086 1.086a1.75 1.75 0 0 1 0 2.474l-8.61 8.61c-.21.21-.47.364-.756.445l-3.251.93a.75.75 0 0 1-.927-.928l.929-3.25c.081-.286.235-.547.445-.758l8.61-8.61Zm1.414 1.06a.25.25 0 0 0-.354 0L10.811 3.75l1.439 1.44 1.263-1.264a.25.25 0 0 0 0-.354l-1.086-1.086ZM11.189 6.25l-1.44-1.439-6.486 6.487a.25.25 0 0 0-.064.108l-.558 1.953 1.953-.558a.25.25 0 0 0 .108-.064l6.487-6.487Z"/></svg>
            </a>
          </div>
          <div class="sb-card-intent">${escapeHtml(s.intent)}</div>
          <div class="sb-card-queries">${queryHtml}</div>
        </div>
      `;
    }).join('');
  }

  // ── Search + Filter ──
  function filterSamples() {
    const searchEl = document.getElementById('sb-search');
    const productEl = document.getElementById('sb-product-filter');
    if (!searchEl || !productEl) return;

    const query = searchEl.value.toLowerCase().trim();
    const product = productEl.value;

    let filtered = allSamples;

    if (product) {
      filtered = filtered.filter(s => s.product === product);
    }

    if (query) {
      const words = query.split(/\s+/);
      filtered = filtered.filter(s => {
        const text = (s.intent + ' ' + (Array.isArray(s.query) ? s.query.join(' ') : s.query)).toLowerCase();
        return words.every(w => text.includes(w));
      });
    }

    renderSamples(filtered);
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // ── Init ──
  document.addEventListener('DOMContentLoaded', () => {
    loadSamples();

    const searchEl = document.getElementById('sb-search');
    const productEl = document.getElementById('sb-product-filter');
    if (searchEl) searchEl.addEventListener('input', filterSamples);
    if (productEl) productEl.addEventListener('change', filterSamples);
  });
</script>
