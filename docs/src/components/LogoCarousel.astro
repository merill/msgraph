  { name: "Snowflake", url: "https://docs.snowflake.com/en/user-guide/cortex-code/cortex-code", lightSrc: "/logos/snowflake/light.svg", darkSrc: "/logos/snowflake/dark.svg" },
];

// Split into two rows (server-side — will be shuffled client-side)
const row1 = logos.filter((_, i) => i % 2 === 0);
const row2 = logos.filter((_, i) => i % 2 === 1);

// Helper to render a logo link
function renderLogoHTML(logo: typeof logos[0]) {
  const w = logo.width || '150px';
  return `<a href="${logo.url}" target="_blank" rel="noopener noreferrer" class="logo-carousel-link" style="text-decoration:none;border:none;">
    <img class="logo-carousel-img logo-light" style="width:${w};max-width:100%;" src="${logo.lightSrc}" alt="${logo.name}" loading="lazy" />
    <img class="logo-carousel-img logo-dark" style="width:${w};max-width:100%;" src="${logo.darkSrc}" alt="${logo.name}" loading="lazy" />
  </a>`;
}
---

<div class="logo-carousel-container">
  <div class="logo-carousel" id="logo-carousel-row1">
    <div class="logo-carousel-track" data-direction="normal" data-speed="50">
      {row1.map((logo) => (
        <a href={logo.url} target="_blank" rel="noopener noreferrer" class="logo-carousel-link" data-logo={JSON.stringify(logo)}>
          <img class="logo-carousel-img logo-light" style={`width:${logo.width || '150px'};max-width:100%;`} src={logo.lightSrc} alt={logo.name} loading="lazy" />
          <img class="logo-carousel-img logo-dark" style={`width:${logo.width || '150px'};max-width:100%;`} src={logo.darkSrc} alt={logo.name} loading="lazy" />
        </a>
      ))}
    </div>
  </div>
  <div class="logo-carousel" id="logo-carousel-row2">
    <div class="logo-carousel-track" data-direction="reverse" data-speed="60">
      {row2.map((logo) => (
        <a href={logo.url} target="_blank" rel="noopener noreferrer" class="logo-carousel-link" data-logo={JSON.stringify(logo)}>
          <img class="logo-carousel-img logo-light" style={`width:${logo.width || '150px'};max-width:100%;`} src={logo.lightSrc} alt={logo.name} loading="lazy" />
          <img class="logo-carousel-img logo-dark" style={`width:${logo.width || '150px'};max-width:100%;`} src={logo.darkSrc} alt={logo.name} loading="lazy" />
        </a>
      ))}
    </div>
  </div>
</div>

<script>
  // Shuffle logos and duplicate for seamless infinite scroll
  function initCarousel() {
    document.querySelectorAll('.logo-carousel-track').forEach((track) => {
      const links = Array.from(track.querySelectorAll('.logo-carousel-link'));
      const direction = track.getAttribute('data-direction') || 'normal';
      const speed = track.getAttribute('data-speed') || '50';

      // Fisher-Yates shuffle
      for (let i = links.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [links[i], links[j]] = [links[j], links[i]];
      }

      // Clear and re-append shuffled + duplicated
      track.innerHTML = '';
      links.forEach((link) => track.appendChild(link.cloneNode(true)));
      links.forEach((link) => track.appendChild(link.cloneNode(true)));

      // Apply animation
      (track as HTMLElement).style.animation = `logo-scroll ${speed}s linear infinite ${direction}`;
    });
  }

  // Run on load and on Astro page transitions
  initCarousel();
  document.addEventListener('astro:after-swap', initCarousel);
</script>
