---
/*
  LogoCarousel component for the msgraph docs site.
  Ported from agentskills.io's React component to Astro.

  Features:
  - Two rows scrolling in opposite directions (CSS marquee)
  - Shuffled on each page load for fair exposure
  - Light/dark mode logo variants via data-theme attribute
  - Reduced motion support

  To add a new logo:
  1. Add light.svg and dark.svg to docs/public/logos/[brand]/
  2. Add entry to the logos array below
*/

const logos = [
  { name: "Junie", url: "https://junie.jetbrains.com/", lightSrc: "/logos/junie/light.svg", darkSrc: "/logos/junie/dark.svg" },
  { name: "Gemini CLI", url: "https://geminicli.com", lightSrc: "/logos/gemini-cli/light.svg", darkSrc: "/logos/gemini-cli/dark.svg" },
  { name: "Autohand Code CLI", url: "https://autohand.ai/", lightSrc: "/logos/autohand/light.svg", darkSrc: "/logos/autohand/dark.svg", width: "120px" },
  { name: "OpenCode", url: "https://opencode.ai/", lightSrc: "/logos/opencode/light.svg", darkSrc: "/logos/opencode/dark.svg" },
  { name: "OpenHands", url: "https://www.all-hands.dev/", lightSrc: "/logos/openhands/light.svg", darkSrc: "/logos/openhands/dark.svg" },
  { name: "Mux", url: "https://mux.coder.com/", lightSrc: "/logos/mux/light.svg", darkSrc: "/logos/mux/dark.svg", width: "120px" },
  { name: "Cursor", url: "https://cursor.com/", lightSrc: "/logos/cursor/light.svg", darkSrc: "/logos/cursor/dark.svg" },
  { name: "Amp", url: "https://ampcode.com/", lightSrc: "/logos/amp/light.svg", darkSrc: "/logos/amp/dark.svg", width: "120px" },
  { name: "Letta", url: "https://www.letta.com/", lightSrc: "/logos/letta/light.svg", darkSrc: "/logos/letta/dark.svg" },
  { name: "Firebender", url: "https://firebender.com/", lightSrc: "/logos/firebender/light.svg", darkSrc: "/logos/firebender/dark.svg" },
  { name: "Goose", url: "https://block.github.io/goose/", lightSrc: "/logos/goose/light.png", darkSrc: "/logos/goose/dark.png" },
  { name: "GitHub", url: "https://github.com/", lightSrc: "/logos/github/light.svg", darkSrc: "/logos/github/dark.svg" },
  { name: "VS Code", url: "https://code.visualstudio.com/", lightSrc: "/logos/vscode/light.svg", darkSrc: "/logos/vscode/dark.svg" },
  { name: "Claude Code", url: "https://claude.ai/code", lightSrc: "/logos/claude-code/light.svg", darkSrc: "/logos/claude-code/dark.svg" },
  { name: "Claude", url: "https://claude.ai/", lightSrc: "/logos/claude-ai/light.svg", darkSrc: "/logos/claude-ai/dark.svg" },
  { name: "OpenAI Codex", url: "https://developers.openai.com/codex", lightSrc: "/logos/oai-codex/light.svg", darkSrc: "/logos/oai-codex/dark.svg" },
  { name: "Piebald", url: "https://piebald.ai", lightSrc: "/logos/piebald/light.svg", darkSrc: "/logos/piebald/dark.svg" },
  { name: "Factory", url: "https://factory.ai/", lightSrc: "/logos/factory/light.svg", darkSrc: "/logos/factory/dark.svg" },
  { name: "pi", url: "https://shittycodingagent.ai/", lightSrc: "/logos/pi/light.svg", darkSrc: "/logos/pi/dark.svg", width: "80px" },
