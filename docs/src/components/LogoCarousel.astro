  { name: "Mistral AI Vibe", url: "https://github.com/mistralai/mistral-vibe", lightSrc: "/logos/mistral-vibe/light.svg", darkSrc: "/logos/mistral-vibe/dark.svg", width: "80px" },
  { name: "Command Code", url: "https://commandcode.ai/", lightSrc: "/logos/command-code/light.svg", darkSrc: "/logos/command-code/dark.svg", width: "200px" },
  { name: "Ona", url: "https://ona.com", lightSrc: "/logos/ona/light.svg", darkSrc: "/logos/ona/dark.svg", width: "120px" },
